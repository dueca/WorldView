<?xml version='1.0' encoding='UTF-8'?>
<world xmlns="https://dueca.tudelft.nl"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://dueca.tudelft.nl https://raw.githubusercontent.com/dueca/WorldView/master/vsg-viewer/vsgworld.xsd">

  <!-- random "car" model -->
  <static name="car3" type="model">
    <file>piper_pa18.glb</file>
  </static>

  <!-- transform node to the car location -->
  <static name="car2base" type="static-transform">
    <param name="xyz">4, -2, -2</param>
    <child>car3</child>
  </static>

  <static name="grass" type="static-model">
    <file>grass.glb</file>
  </static>

  <!-- arrow orientation -->
  <static name="arrows" type="static-model">
    <file>arrows.glb</file>
  </static>

  <!-- world orientation -->
  <static name="world-base" type="tiled-transform" root="true">
    <param name="tilesizexyz">20.0, 20.0, 0.0</param>
    <param name="xyz"> 0, 0, 0.05 </param>
    <param name="phithetapsi">0, 0, 0 </param>
    <param name="scalexyz">100, 100, 100</param>
    <child>grass</child>
  </static>

  <!-- world total -->
  <static name="arrow-base" type="static-transform" root="true">
    <param name="xyz"> 0, 0, 0 </param>
    <param name="phithetapsi">0, 0, 0 </param>
    <child>arrows</child>
  </static>

  <!-- helmet location -->
  <!--
  <static name="helmet" type="static-model">
    <file>FlightHelmet.vsgb</file>
  </static>
  <static name="helmet-base" parent="root" type="static-transform">
    <param name="scalexyz"> 10, 10, 10 </param>
    <param name="xyz">2, 0, 0</param>
    <child>helmet</child>
  </static>
  -->

  <!-- simple ambient light -->
  <static name="ambient" type="ambient-light">
    <param name="color"> 1, 1, 1</param>
    <param name="intensity"> 0.4 </param>
  </static>


  <static name="road" type="static-model">
    <file>myroad.glb</file>
  </static>

  <static name="road-base" root="true" type="static-transform">
    <param name="xyz">0, 0, 0</param>
    <child>road</child>
  </static>

  <static name="skydome" type="static-model">
    <file>skydome.glb</file>
  </static>

  <static name="skydomeloc" root="true" type="centered-transform">
    <param name="scalexyz">100, 100, 100</param>
    <param name="xyz">0, 0, 10</param>
    <child>skydome</child>
  </static>


  <!-- directed light -->
  <static name="sun" type="directional-light" root="true">
    <param name="color"> 1, 1, 1</param>
    <param name="intensity"> 0.8 </param>
    <param name="direction"> 0.2, -0.0, 0.7 </param>
  </static>

</world>